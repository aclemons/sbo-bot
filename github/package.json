{
  "name": "sbo-bot-github",
  "version": "0.0.1",
  "private": true,
  "description": "github bot for automating SBo submissions.",
  "author": "Andrew Clemons",
  "license": "MIT",
  "homepage": "https://github.com/aclemons/sbo-bot",
  "keywords": [
    "probot",
    "github",
    "probot-app"
  ],
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "lint-fix-pre-commit": "eslint --fix",
    "format": "prettier --write src",
    "start": "probot run ./lib/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-ssm": "3.1075.0",
    "axios": "1.18.1",
    "express": "5.2.1",
    "pino": "10.3.1",
    "pino-http": "11.0.0",
    "probot": "14.3.2"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@tsconfig/node-lts": "24.0.0",
    "@types/express": "5.0.6",
    "@types/node": "24.13.2",
    "globals": "17.6.0",
    "prettier": "3.8.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0"
  },
  "engines": {
    "node": "24.17.0"
  }
}
